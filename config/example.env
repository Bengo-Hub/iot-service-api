# IoT Service environment template
IOT_APP_NAME=iot-service
IOT_APP_ENV=development
IOT_APP_REGION=africa-east-1
IOT_APP_VERSION=0.1.0

IOT_HTTP_HOST=0.0.0.0
IOT_HTTP_PORT=4006
IOT_HTTP_READ_TIMEOUT=20s
IOT_HTTP_WRITE_TIMEOUT=20s
IOT_HTTP_IDLE_TIMEOUT=90s
# TLS configuration for HTTPS (mkcert certificates) - local development only
# Uncomment and set paths to enable HTTPS
# IOT_HTTP_TLS_CERT_FILE=./config/certs/iot.codevertex.local.pem
# IOT_HTTP_TLS_KEY_FILE=./config/certs/iot.codevertex.local-key.pem

IOT_POSTGRES_URL=postgres://postgres:postgres@localhost:5432/iot?sslmode=disable
IOT_POSTGRES_MAX_OPEN_CONNS=30
IOT_POSTGRES_MAX_IDLE_CONNS=15
IOT_POSTGRES_CONN_MAX_LIFETIME=45m

IOT_REDIS_ADDR=localhost:6380
IOT_REDIS_USERNAME=
IOT_REDIS_PASSWORD=
IOT_REDIS_DB=0
IOT_REDIS_TLS_REQUIRED=false
IOT_REDIS_DIAL_TIMEOUT=5s

IOT_EVENT_BUS=nats
IOT_NATS_URL=nats://localhost:4222
IOT_NATS_STREAM=iot
IOT_NATS_DELIVER_GROUP=iot-workers
IOT_NATS_DLQ_STREAM=iot-dlq

IOT_OTLP_ENDPOINT=

# Auth Service SSO (JWT) settings
IOT_AUTH_SERVICE_URL=https://sso.codevertexitsolutions.com
IOT_AUTH_ISSUER=https://sso.codevertexitsolutions.com
IOT_AUTH_AUDIENCE=codevertex
IOT_AUTH_JWKS_URL=https://sso.codevertexitsolutions.com/api/v1/.well-known/jwks.json
IOT_AUTH_JWKS_CACHE_TTL=3600s
IOT_AUTH_JWKS_REFRESH_INTERVAL=300s
IOT_AUTH_ENABLE_API_KEY_AUTH=true
IOT_INTERNAL_SERVICE_KEY=

